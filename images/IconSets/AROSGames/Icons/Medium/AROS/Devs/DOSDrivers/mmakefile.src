include $(SRCDIR)/config/aros.cfg

STORAGEICONS := ICD0 ICD1 IDF0 IDF1 ISO0 PC0
DEVSICONS    := AUDIO PAR PIPE PRT SER SER0 SER1

#MM- iconset-AROSGames-wbench-icons-aros-clean : iconset-AROSGames-wbench-icons-devs-dosdrivers-clean iconset-AROSGames-wbench-icons-storage-dosdrivers-clean
#MM- iconset-AROSGames-wbench-icons-aros : iconset-AROSGames-wbench-icons-devs-dosdrivers iconset-AROSGames-wbench-icons-storage-dosdrivers

%build_dual_icons mmake=iconset-AROSGames-wbench-icons-devs-dosdrivers icons=$(DEVSICONS) \
             dir=$(AROS_DEVS)/DOSDrivers

%build_dual_icons mmake=iconset-AROSGames-wbench-icons-storage-dosdrivers icons=$(STORAGEICONS) \
             dir=$(AROS_STORAGE)/DOSDrivers

#MM- icons-wbench-devs-dosdrivers : arosgames-icons-wbench-devs-dosdrivers
%build_dual_icons mmake=arosgames-icons-wbench-devs-dosdrivers icons=$(DEVSICONS) \
             dir=$(AROS_PRESETS)/Icons/AROSGames/Default/$(AROS_DIR_AROS)/$(AROS_DIR_DEVS)/DOSDrivers

#MM- icons-wbench-storage-dosdrivers : arosgames-icons-wbench-storage-dosdrivers
%build_dual_icons mmake=arosgames-icons-wbench-storage-dosdrivers icons=$(STORAGEICONS) \
             dir=$(AROS_PRESETS)/Icons/AROSGames/Default/$(AROS_DIR_AROS)/$(AROS_DIR_STORAGE)/DOSDrivers
