include $(SRCDIR)/config/aros.cfg

ADDITIONALICONS := ACPITool PCITool 

#MM- iconset-AROSGames-additional-icons-aros-clean : iconset-AROSGames-additional-icons-aros-tools-hardware-clean
#MM- iconset-AROSGames-additional-icons-aros-debug : iconset-AROSGames-additional-icons-aros-tools-hardware
%build_dual_icons mmake=iconset-AROSGames-additional-icons-aros-tools-hardware icons=$(ADDITIONALICONS) \
             dir=$(AROS_TOOLS)/Hardware
