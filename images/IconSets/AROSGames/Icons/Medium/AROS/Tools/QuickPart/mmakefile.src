include $(SRCDIR)/config/aros.cfg

#MM- iconset-AROSGames-wbench-icons-aros-tools-clean : iconset-AROSGames-wbench-icons-aros-tools-quickpart-clean
#MM- iconset-AROSGames-wbench-icons-aros-tools : iconset-AROSGames-wbench-icons-aros-tools-quickpart

%build_dual_icons mmake=iconset-AROSGames-wbench-icons-aros-tools-quickpart icons=QuickPart \
             dir=$(AROS_TOOLS)/QuickPart

#MM- icons-wbench-tools : arosgames-icons-wbench-tools-quickpart
%build_dual_icons mmake=arosgames-icons-wbench-tools-quickpart icons=QuickPart \
             dir=$(AROS_PRESETS)/Icons/AROSGames/Default/$(AROS_DIR_AROS)/$(AROS_DIR_TOOLS)/QuickPart
