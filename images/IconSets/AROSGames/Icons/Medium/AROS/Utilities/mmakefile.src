include $(SRCDIR)/config/aros.cfg

BASEICONS := Clock Help Installer More MultiView

#MM- iconset-AROSGames-wbench-icons-aros-clean : iconset-AROSGames-wbench-icons-aros-utilities-clean
#MM- iconset-AROSGames-wbench-icons-aros : iconset-AROSGames-wbench-icons-aros-utilities

%build_dual_icons mmake=iconset-AROSGames-wbench-icons-aros-utilities icons=$(BASEICONS) \
             dir=$(AROS_UTILITIES)

#MM- icons-wbench-utilities : arosgames-icons-wbench-utilities
%build_dual_icons mmake=arosgames-icons-wbench-utilities icons=$(BASEICONS) \
             dir=$(AROS_PRESETS)/Icons/AROSGames/Default/$(AROS_DIR_AROS)/$(AROS_DIR_UTILITIES)
