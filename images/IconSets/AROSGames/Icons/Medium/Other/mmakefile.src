include $(SRCDIR)/config/aros.cfg

ICONS := Mouse Pointer

#MM- themes-arosgames-icons-clean : themes-arosgames-icons-other-clean
#MM- themes-arosgames-icons : themes-arosgames-icons-other
%build_icons mmake=themes-arosgames-icons-other icons=$(ICONS) \
             dir=$(AROS_CONTRIB)/Icons/AROSGames/Other
