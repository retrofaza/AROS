include $(SRCDIR)/config/aros.cfg

ADDITIONALICONS := PCITool 

#MM- iconset-AROSGamesSmall-additional-icons-aros-clean : iconset-AROSGamesSmall-additional-icons-aros-debug-hardware-clean
#MM- iconset-AROSGamesSmall-additional-icons-aros-debug : iconset-AROSGamesSmall-additional-icons-aros-debug-hardware

%build_icons mmake=iconset-AROSGamesSmall-additional-icons-aros-debug-hardware icons=$(ADDITIONALICONS) \
             dir=$(AROS_DEBUG)/Hardware

#MM- icons-developer-debug-hardware : arosgamessmall-icons-developer-developer-debug-hardware
%build_icons mmake=arosgamessmall-icons-developer-developer-debug-hardware icons=$(ADDITIONALICONS) \
             dir=$(AROS_PRESETS)/Icons/AROSGames/Small/$(AROS_DIR_AROS)/$(AROS_DIR_DEVELOPER)/Debug/Hardware
