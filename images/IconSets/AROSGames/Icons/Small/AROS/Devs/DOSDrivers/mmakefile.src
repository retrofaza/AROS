include $(SRCDIR)/config/aros.cfg

STORAGEICONS := ICD0 ICD1 IDF0 IDF1 ISO0 PC0
DEVSICONS    := PAR PIPE PRT SER SER0 SER1

#MM- iconset-AROSGamesSmall-wbench-icons-aros-clean : iconset-AROSGamesSmall-wbench-icons-devs-dosdrivers-clean iconset-AROSGamesSmall-wbench-icons-storage-dosdrivers-clean
#MM- iconset-AROSGamesSmall-wbench-icons-aros : iconset-AROSGamesSmall-wbench-icons-devs-dosdrivers iconset-AROSGamesSmall-wbench-icons-storage-dosdrivers

%build_icons mmake=iconset-AROSGamesSmall-wbench-icons-devs-dosdrivers icons=$(DEVSICONS) \
             dir=$(AROS_DEVS)/DOSDrivers

%build_icons mmake=iconset-AROSGamesSmall-wbench-icons-storage-dosdrivers icons=$(STORAGEICONS) \
             dir=$(AROSDIR)/Storage/DOSDrivers

#MM- icons-wbench-devs-dosdrivers : arosgamessmall-icons-wbench-devs-dosdrivers
%build_icons mmake=arosgamessmall-icons-wbench-devs-dosdrivers icons=$(DEVSICONS) \
             dir=$(AROS_PRESETS)/Icons/AROSGames/Small/$(AROS_DIR_AROS)/$(AROS_DIR_DEVS)/DOSDrivers

#MM- icons-wbench-storage-dosdrivers : arosgamessmall-icons-wbench-storage-dosdrivers
%build_icons mmake=arosgamessmall-icons-wbench-storage-dosdrivers icons=$(STORAGEICONS) \
             dir=$(AROS_PRESETS)/Icons/AROSGames/Small/$(AROS_DIR_AROS)/$(AROS_DIR_STORAGE)/DOSDrivers
