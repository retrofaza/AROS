include $(SRCDIR)/config/aros.cfg

STORAGEICONS := Wrapper
DEVSICONS    := ATI IntelGMA NVidia VMWare SAGA

#MM- iconset-AROSGamesSmall-wbench-icons-aros-clean : iconset-AROSGamesSmall-wbench-icons-devs-monitors-clean iconset-AROSGamesSmall-wbench-icons-storage-monitors-clean
#MM- iconset-AROSGamesSmall-wbench-icons-aros : iconset-AROSGamesSmall-wbench-icons-devs-monitors iconset-AROSGamesSmall-wbench-icons-storage-monitors

%build_icons mmake=iconset-AROSGamesSmall-wbench-icons-devs-monitors icons=$(DEVSICONS) image=Wrapper.png \
             dir=$(AROS_DEVS)/Monitors

%build_icons mmake=iconset-AROSGamesSmall-wbench-icons-storage-monitors icons=$(STORAGEICONS) image=Wrapper.png \
             dir=$(AROSDIR)/Storage/Monitors

#MM- icons-wbench-devs-monitors : arosgamessmall-icons-wbench-devs-monitors
%build_icons mmake=arosgamessmall-icons-wbench-devs-monitors icons=$(DEVSICONS) image=Wrapper.png \
             dir=$(AROS_PRESETS)/Icons/AROSGames/Small/$(AROS_DIR_AROS)/$(AROS_DIR_STORAGE)/Monitors

#MM- icons-wbench-devs-monitors : arosgamessmall-icons-wbench-storage-monitors
%build_icons mmake=arosgamessmall-icons-wbench-storage-monitors icons=$(STORAGEICONS) image=Wrapper.png \
             dir=$(AROS_PRESETS)/Icons/AROSGames/Small/$(AROS_DIR_AROS)/$(AROS_DIR_STORAGE)/Monitors
