include $(SRCDIR)/config/aros.cfg

ICONS := Help Catalogs Flags Countries Languages

#MM- iconset-AROSGamesSmall-wbench-icons-aros-clean : iconset-AROSGamesSmall-wbench-icons-aros-locale-clean
#MM- iconset-AROSGamesSmall-wbench-icons-aros : iconset-AROSGamesSmall-wbench-icons-aros-locale

%build_icons mmake=iconset-AROSGamesSmall-wbench-icons-aros-locale icons=$(ICONS) \
             dir=$(AROS_LOCALE)

#MM- icons-wbench-locale : arosgamessmall-icons-wbench-locale
%build_icons mmake=arosgamessmall-icons-wbench-locale icons=$(ICONS) \
             dir=$(AROS_PRESETS)/Icons/AROSGames/Small/$(AROS_DIR_AROS)/$(AROS_DIR_LOCALE)
