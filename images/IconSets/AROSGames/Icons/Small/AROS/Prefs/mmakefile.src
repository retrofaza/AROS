include $(SRCDIR)/config/aros.cfg

BASEICONS := Time Locale Serial Presets Input IControl Font ScreenMode Palette Pointer Printer
ADDITIONALICONS := AHI Appearance Boot  \
 ReqTools Wanderer Zune Editor Trackdisk PSI Network Trident \
 OpenURL BoingIconBar

#MM- iconset-AROSGamesSmall-wbench-icons-aros-clean : iconset-AROSGamesSmall-wbench-icons-aros-prefs-clean
#MM- iconset-AROSGamesSmall-additional-icons-aros-clean : iconset-AROSGamesSmall-additional-icons-aros-prefs-clean
#MM- iconset-AROSGamesSmall-wbench-icons-aros : iconset-AROSGamesSmall-wbench-icons-aros-prefs
#MM- iconset-AROSGamesSmall-additional-icons-aros : iconset-AROSGamesSmall-additional-icons-aros-prefs

%build_icons mmake=iconset-AROSGamesSmall-wbench-icons-aros-prefs icons=$(BASEICONS) \
             dir=$(AROS_PREFS)

%build_icons mmake=iconset-AROSGamesSmall-additional-icons-aros-prefs icons=$(ADDITIONALICONS) \
             dir=$(AROS_PREFS)

#MM- icons-wbench-prefs : arosgamessmall-icons-wbench-prefs
%build_icons mmake=arosgamessmall-icons-wbench-prefs icons=$(BASEICONS) \
             dir=$(AROS_PRESETS)/Icons/AROSGames/Small/$(AROS_DIR_AROS)/$(AROS_DIR_PREFS)

#MM- icons-additional-wbench-prefs : arosgamessmall-icons-additional-wbench-prefs
%build_icons mmake=arosgamessmall-icons-additional-wbench-prefs icons=$(ADDITIONALICONS) \
             dir=$(AROS_PRESETS)/Icons/AROSGames/Small/$(AROS_DIR_AROS)/$(AROS_DIR_PREFS)
