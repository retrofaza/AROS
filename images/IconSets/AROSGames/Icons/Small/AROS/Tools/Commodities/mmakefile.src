include $(SRCDIR)/config/aros.cfg

ICONS := AltKeyQ ASCIITable AutoPoint Blanker ClickToFront DepthMenu Exchange \
         FKey NoCapsLock Opaque  

#MM- iconset-AROSGamesSmall-wbench-icons-aros-clean : iconset-AROSGamesSmall-wbench-icons-aros-tools-commodities-clean
#MM- iconset-AROSGamesSmall-wbench-icons-aros : iconset-AROSGamesSmall-wbench-icons-aros-tools-commodities

%build_icons mmake=iconset-AROSGamesSmall-wbench-icons-aros-tools-commodities icons=$(ICONS) \
             dir=$(AROS_TOOLS)/$(AROS_DIR_COMMODITIES)

#MM- icons-wbench-tools-commodities : arosgamessmall-icons-wbench-tools-commodities
%build_icons mmake=arosgamessmall-icons-wbench-tools-commodities icons=$(ICONS) \
             dir=$(AROS_PRESETS)/Icons/AROSGames/Small/$(AROS_DIR_AROS)/$(AROS_DIR_TOOLS)/$(AROS_DIR_COMMODITIES)
