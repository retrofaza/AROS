include $(SRCDIR)/config/aros.cfg

BASEICONS := Calculator HDToolBox InstallAROS Editor Commodities \
         ShowConfig KeyShow InitPrinter PrintFiles GraphicDump
ADDITIONALICONS := WiMP ScreenGrabber SysExplorer BoingIconBar

#MM- iconset-AROSGamesSmall-wbench-icons-aros-clean : iconset-AROSGamesSmall-wbench-icons-aros-tools-clean
#MM- iconset-AROSGamesSmall-additional-icons-aros-clean : iconset-AROSGamesSmall-additional-icons-aros-tools-clean
#MM- iconset-AROSGamesSmall-wbench-icons-aros : iconset-AROSGamesSmall-wbench-icons-aros-tools
#MM- iconset-AROSGamesSmall-additional-icons-aros : iconset-AROSGamesSmall-additional-icons-aros-tools

%build_icons mmake=iconset-AROSGamesSmall-wbench-icons-aros-tools icons=$(BASEICONS) \
             dir=$(AROS_TOOLS)

%build_icons mmake=iconset-AROSGamesSmall-additional-icons-aros-tools icons=$(ADDITIONALICONS) \
             dir=$(AROS_TOOLS)

#MM- icons-wbench-tools : arosgamessmall-icons-wbench-tools
%build_icons mmake=arosgamessmall-icons-wbench-tools icons=$(BASEICONS) \
             dir=$(AROS_PRESETS)/Icons/AROSGames/Small/$(AROS_DIR_AROS)/$(AROS_DIR_TOOLS)

#MM- icons-additional-wbench-tools : arosgamessmall-icons-additional-wbench-tools
%build_icons mmake=arosgamessmall-icons-additional-wbench-tools icons=$(ADDITIONALICONS) \
             dir=$(AROS_PRESETS)/Icons/AROSGames/Small/$(AROS_DIR_AROS)/$(AROS_DIR__TOOLS)
