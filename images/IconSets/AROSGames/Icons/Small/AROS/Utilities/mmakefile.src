include $(SRCDIR)/config/aros.cfg

BASEICONS := Clock Help Installer More MultiView

#MM- iconset-AROSGamesSmall-wbench-icons-aros-clean : iconset-AROSGamesSmall-wbench-icons-aros-utilities-clean
#MM- iconset-AROSGamesSmall-wbench-icons-aros : iconset-AROSGamesSmall-wbench-icons-aros-utilities

%build_icons mmake=iconset-AROSGamesSmall-wbench-icons-aros-utilities icons=$(BASEICONS) \
             dir=$(AROS_UTILITIES)

#MM- icons-wbench-utilities : arosgamessmall-icons-wbench-utilities
%build_icons mmake=arosgamessmall-icons-wbench-utilities icons=$(BASEICONS) \
             dir=$(AROS_PRESETS)/Icons/AROSGames/Small/$(AROS_DIR_AROS)/$(AROS_DIR_UTILITIES)
