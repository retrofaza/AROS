include $(SRCDIR)/config/aros.cfg

ICONS := Mouse Pointer

#MM- themes-AROSGamesSmall-icons-clean : themes-AROSGamesSmall-icons-other-clean
#MM- themes-AROSGamesSmall-icons : themes-AROSGamesSmall-icons-other
%build_icons mmake=themes-AROSGamesSmall-icons-other icons=$(ICONS) \
             dir=$(AROS_CONTRIB)/Icons/AROSGames/Other
