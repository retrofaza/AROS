arosgamestiny-icon-images : $(AROS_PRESETS)/Icons/AROSGames/Tiny/Images/Drawer $(AROS_PRESETS)/Icons/AROSGames/Tiny/Images/File $(AROS_PRESETS)/Icons/AROSGames/Tiny/Images/CDROM $(AROS_PRESETS)/Icons/AROSGames/Tiny/Images/Computer $(AROS_PRESETS)/Icons/AROSGames/Tiny/Images/Harddisk $(AROS_PRESETS)/Icons/AROSGames/Tiny/Images/RAMdisk $(AROS_PRESETS)/Icons/AROSGames/Tiny/Images/USBdisk

