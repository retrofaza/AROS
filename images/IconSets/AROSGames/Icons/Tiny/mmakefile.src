include $(SRCDIR)/config/aros.cfg

$(AROS_PRESETS)/Icons/AROSGames/Tiny/Images/Drawer : $(SRCDIR)/$(CURDIR)/Drawer.png
	@$(MKDIR) -p "$(dir $@)"
	$(CP) $< $@

$(AROS_PRESETS)/Icons/AROSGames/Tiny/Images/File : $(SRCDIR)/$(CURDIR)/File.png
	@$(MKDIR) -p "$(dir $@)"
	$(CP) $< $@

$(AROS_PRESETS)/Icons/AROSGames/Tiny/Images/CDROM : $(SRCDIR)/$(CURDIR)/CDROM.png
	@$(MKDIR) -p "$(dir $@)"
	$(CP) $< $@

$(AROS_PRESETS)/Icons/AROSGames/Tiny/Images/Computer : $(SRCDIR)/$(CURDIR)/Computer.png
	@$(MKDIR) -p "$(dir $@)"
	$(CP) $< $@

$(AROS_PRESETS)/Icons/AROSGames/Tiny/Images/Harddisk : $(SRCDIR)/$(CURDIR)/Harddisk.png
	@$(MKDIR) -p "$(dir $@)"
	$(CP) $< $@

$(AROS_PRESETS)/Icons/AROSGames/Tiny/Images/RAMdisk : $(SRCDIR)/$(CURDIR)/RAMdisk.png
	@$(MKDIR) -p "$(dir $@)"
	$(CP) $< $@

$(AROS_PRESETS)/Icons/AROSGames/Tiny/Images/USBdisk : $(SRCDIR)/$(CURDIR)/USBdisk.png
	@$(MKDIR) -p "$(dir $@)"
	$(CP) $< $@

